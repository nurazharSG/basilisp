from typing import Callable, Generic, Iterable, TypeVar, overload

from typing_extensions import Self

from basilisp.lang.interfaces import IPersistentMap, ISeq, ISeqable

T = TypeVar("T")

class Cons(Generic[T]):
    def __new__(
        cls,
        /,
        first: T,
        rest: ISeq[T] | None = None,
        *,
        meta: IPersistentMap | None = None,
    ) -> Cons[T]: ...
    def cons(self, /, *elems: T) -> Self: ...
    def empty(self, /) -> Self: ...
    @property
    def first(self, /) -> T: ...
    @property
    def is_empty(self, /) -> bool: ...
    @property
    def meta(self, /) -> IPersistentMap | None: ...
    @property
    def rest(self, /) -> ISeq[T]: ...
    def with_meta(self, /, meta: IPersistentMap | None) -> Self: ...

class EmptySequence(Generic[T]):
    def __new__(cls, /, *, meta: IPersistentMap | None = None) -> EmptySequence[T]: ...
    def cons(self, /, *elems: T) -> Self: ...
    def empty(self, /) -> Self: ...
    @property
    def first(self, /) -> T: ...
    @property
    def is_empty(self, /) -> bool: ...
    @property
    def meta(self, /) -> IPersistentMap | None: ...
    @property
    def rest(self, /) -> ISeq[T]: ...
    def with_meta(self, /, meta: IPersistentMap | None) -> Self: ...

class LazySeq(Generic[T]):
    def __new__(
        cls,
        /,
        gen: Callable[[], ISeq[T] | ISeqable[T] | None],
        seq: ISeq[T] | None = None,
        *,
        meta: IPersistentMap | None = None,
    ) -> LazySeq: ...
    def _compute_seq(self, /) -> ISeq[T] | None: ...
    def cons(self, /, *elems: T) -> Self: ...
    def empty(self, /) -> Self: ...
    @property
    def first(self, /) -> T: ...
    @property
    def is_empty(self, /) -> bool: ...
    @property
    def is_realized(self, /) -> bool: ...
    @property
    def meta(self, /) -> IPersistentMap: ...
    def with_meta(self, /, meta: IPersistentMap | None) -> Self: ...
    @property
    def rest(self, /) -> ISeq[T]: ...
    def seq(self, /) -> ISeq[T] | None: ...

class SeqIterator(Generic[T]):
    def __new__(cls, /, cur: Iterable[T]) -> SeqIterator[T]: ...
    def __iter__(self, /) -> SeqIterator[T]: ...
    def __next__(self, /) -> T | None: ...

def sequence(s: Iterable[T], support_single_use: bool = False) -> ISeq[T]: ...
@overload
def to_seq(s: None) -> None: ...
@overload
def to_seq(s: ISeq[T]) -> ISeq[T] | None: ...
@overload
def to_seq(s: ISeqable[T]) -> ISeq[T] | None: ...
@overload
def to_seq(s: Iterable[T] | None) -> ISeq[T] | None: ...
